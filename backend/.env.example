# Environment — 'staging' or 'production'
NODE_ENV=staging

# Sheets — staging or production sheet ID
SHEET_ID=

# Apps Script web app URL (separate deployment per env, filled in Plan 2)
APPS_SCRIPT_URL=

# Dashboard admin login — Google Sign-In (Web OAuth client)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ALLOWED_ADMIN_EMAIL=majed.engawi@gmail.com
JWT_SECRET=
PASSWORD_HASH=

# Backend API calls — single Desktop OAuth client with combined Sheets + Gmail scopes,
# acting as GMAIL_SENDER via a refresh token. Replaces the legacy service account approach
# (blocked by the malearnsa.com Workspace org policy on service account key creation).
BACKEND_OAUTH_CLIENT_ID=
BACKEND_OAUTH_CLIENT_SECRET=
BACKEND_OAUTH_REFRESH_TOKEN=
GMAIL_SENDER=majid@malearnsa.com

# Anthropic (Noor reasoning layer)
ANTHROPIC_API_KEY=
NOOR_MONTHLY_CAP_USD=100

# Server
PORT=3400
FRONTEND_ORIGIN=https://admin-staging.malearnsa.com
